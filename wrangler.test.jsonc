{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chat-state-durable-object-tests",
  "main": "tests/worker.ts",
  "compatibility_date": "2026-03-17",
  "durable_objects": {
    "bindings": [
      {
        "name": "CHAT_STATE",
        "class_name": "DurableObjectState"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DurableObjectState"]
    }
  ]
}
